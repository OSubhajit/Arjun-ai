# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env
# Never commit .env to version control.

# ── Required ─────────────────────────────────────────────────────────────────

# MongoDB connection string (local or Atlas)
# Example local:  mongodb://localhost:27017/gitapath
# Example Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gitapath?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/gitapath

# OpenRouter API key  →  https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Optional ──────────────────────────────────────────────────────────────────

# AI model to use via OpenRouter (any model slug from https://openrouter.ai/models)
# Default: openai/gpt-3.5-turbo
AI_MODEL=openai/gpt-3.5-turbo

# Google Apps Script webhook URL for OTP emails (leave blank to disable email)
# See README.md → "Email OTP Setup" for instructions
GMAIL_SCRIPT_URL=

# Google AdSense publisher ID (leave blank to disable all ad tags)
# Format: ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_PUB_ID=

# Local development server port (default: 5000)
PORT=5000

# Set to "true" by Render automatically in production — do not set this locally
# RENDER=true
